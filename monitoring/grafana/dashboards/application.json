        "defaults": {
          "unit": "currencyEUR",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "bot_unrealized_pnl_eur",
          "legendFormat": "Unrealized",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
